# Server
PORT=3001
NODE_ENV=development

# Database (Railway PostgreSQL or local Docker)
DATABASE_URL=postgresql://vitals:vitals@localhost:5432/vitals

# AI Provider: claude (Anthropic) or gemini (Google AI Studio — https://aistudio.google.com/apikey)
AI_PROVIDER=claude
AI_API_KEY=your-api-key-here

# Shared API key — sent by frontend as x-api-key header, validated by backend
X_API_KEY=change-me

# Cronometer (legacy scraper)
CRONOMETER_USERNAME=
CRONOMETER_PASSWORD=
CRONOMETER_GWT_HEADER=
CRONOMETER_GWT_PERMUTATION=

# Hevy API
HEVY_API_KEY=
# HEVY_API_BASE=https://api.hevyapp.com/v1  # optional, has default

# Default user ID (single-user)
DB_DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001

# Frontend origin (scheme + host only, no path, no trailing slash). Set this in Railway to allow CORS from your Vercel deployment.
FRONTEND_URL=https://your-app.vercel.app

# Frontend (set in Vercel)
VITE_API_URL=http://localhost:3001
VITE_X_API_KEY=change-me
